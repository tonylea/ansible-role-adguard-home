[Unit]
Description=AdGuard Home: Network-level blocker
After=network.target
ConditionFileIsExecutable={{ adguard_home_install_dir }}/AdGuardHome

[Service]
Type=simple
User={{ adguard_home_user }}
Group={{ adguard_home_group }}
WorkingDirectory={{ adguard_home_work_dir }}
ExecStart={{ adguard_home_install_dir }}/AdGuardHome --no-check-update -c {{ adguard_home_config_dir }}/AdGuardHome.yaml -w {{ adguard_home_work_dir }}
Restart=always
RestartSec=10

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ adguard_home_work_dir }} {{ adguard_home_config_dir }}
AmbientCapabilities=CAP_NET_BIND_SERVICE CAP_NET_RAW

[Install]
WantedBy=multi-user.target